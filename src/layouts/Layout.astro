---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { url } from '../lib/url';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const defaultDesc = lang === 'en' 
  ? 'Consulting, Training, and Embedded Software Development'
  : 'Consultoria, Treinamento e Desenvolvimento em Software Embarcado';

const { title, description = defaultDesc } = Astro.props;
---

<html lang={lang === 'en' ? 'en' : 'pt-BR'}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | Emc Logic</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
