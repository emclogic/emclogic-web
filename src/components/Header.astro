---
import { url } from '../lib/url';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getUrl = (path: string) => url(lang === 'pt' ? path : `/en${path}`);

const navLinks = [
  { label: t('nav.about'), href: getUrl('/#sobre') },
  { label: t('nav.services'), href: getUrl('/#servicos') },
  { label: t('nav.technologies'), href: getUrl('/#tecnologias') },
  { label: t('nav.areas'), href: getUrl('/#areas') },
  { label: t('nav.blog'), href: url('/blog') },
];
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href={url('/')} class="flex items-center shrink-0">
      <img src={url('/images/logo_emc_logic.svg')} alt="Emc Logic" class="h-8 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-gray-700 hover:text-orange-500 transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-4">
      <a
        href={getUrl('/#contato')}
        class="px-5 py-2.5 bg-orange-500 text-white text-sm font-semibold rounded-full hover:bg-orange-600 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
      >
        {t('nav.contact')}
      </a>
      <a href={url('/')} class={`text-xs font-medium hover:text-gray-800 transition-colors ${lang === 'pt' ? 'text-orange-500' : 'text-gray-500'}`}>PT</a>
      <span class="text-gray-300">|</span>
      <a href={url('/en')} class={`text-xs font-medium hover:text-gray-800 transition-colors ${lang === 'en' ? 'text-orange-500' : 'text-gray-500'}`}>EN</a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded text-gray-600 hover:text-gray-900"
      aria-label="Abrir menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 pb-4">
    <ul class="flex flex-col gap-3 pt-3">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block text-sm font-medium text-gray-700 hover:text-orange-500 py-1">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href={getUrl('/#contato')} class="block w-full text-center px-4 py-2 bg-orange-500 text-white text-sm font-semibold rounded-full mt-2 hover:bg-orange-600 transition-colors">
          {t('nav.contact')}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
