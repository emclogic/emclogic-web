---
const navLinks = [
  { label: 'Sobre', href: '/#sobre' },
  { label: 'Serviços', href: '/#servicos' },
  { label: 'Tecnologias', href: '/#tecnologias' },
  { label: 'Áreas', href: '/#areas' },
  { label: 'Blog', href: '/blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href="/" class="flex items-center shrink-0">
      <img src="/images/logo_emc_logic.svg" alt="Emc Logic" class="h-8 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-gray-700 hover:text-orange-500 transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <a
        href="/#contato"
        class="px-4 py-2 bg-orange-500 text-white text-sm font-semibold rounded hover:bg-orange-600 transition-colors"
      >
        Contato
      </a>
      <a href="/" class="text-xs font-medium text-gray-500 hover:text-gray-800 transition-colors">PT</a>
      <span class="text-gray-300">|</span>
      <a href="/en" class="text-xs font-medium text-gray-500 hover:text-gray-800 transition-colors">EN</a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded text-gray-600 hover:text-gray-900"
      aria-label="Abrir menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 pb-4">
    <ul class="flex flex-col gap-3 pt-3">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block text-sm font-medium text-gray-700 hover:text-orange-500 py-1">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/#contato" class="block w-full text-center px-4 py-2 bg-orange-500 text-white text-sm font-semibold rounded mt-2">
          Contato
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
