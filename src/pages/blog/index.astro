---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Blog" description="Artigos e insights sobre Linux Embarcado, firmware e sistemas embarcados.">
  <section class="py-16 bg-[#0a2540] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">Artigos</h1>
      <p class="text-white/70 text-lg">Fique por dentro de todas as nossas novidades e notícias.</p>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map(post => (
          <article class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow group">
            {post.data.coverImage && (
              <a href={`/blog/${post.id}`} class="block overflow-hidden">
                <img
                  src={`/images/posts/${post.id}/${post.data.coverImage}`}
                  alt={post.data.title}
                  class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </a>
            )}
            {!post.data.coverImage && (
              <div class="w-full h-44 bg-gradient-to-br from-[#0a2540] to-[#1a3a5c] flex items-center justify-center">
                <span class="text-white/20 text-5xl font-bold">{post.data.title.charAt(0)}</span>
              </div>
            )}
            <div class="p-5">
              {post.data.categories && post.data.categories.length > 0 && (
                <div class="flex flex-wrap gap-1 mb-2">
                  {post.data.categories.map(cat => (
                    <span class="text-xs px-2 py-0.5 bg-orange-100 text-orange-700 rounded-full font-medium">{cat}</span>
                  ))}
                </div>
              )}
              <time class="text-xs text-gray-400 mb-2 block" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h2 class="font-bold text-[#0a2540] leading-snug mb-3">
                <a href={`/blog/${post.id}`} class="hover:text-orange-500 transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <a
                href={`/blog/${post.id}`}
                class="text-sm font-medium text-orange-500 hover:text-orange-600 transition-colors"
              >
                Leia mais →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
